# Mock mode is the default.
#for real models through OpenRouter. Set to false to use real models.
USE_MOCKS=false

# Your OpenRouter API key (https://openrouter.ai/keys). Required when USE_MOCKS=false.
OPENROUTER_API_KEY=sk-or-replace-me

OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash

OPENROUTER_DOCUMENT_MODEL=google/gemini-2.5-flash

OPENROUTER_AUDIO_MODEL=google/gemini-2.5-flash

OPENROUTER_ANSWER_MODEL=google/gemini-2.5-flash
